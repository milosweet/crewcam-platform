{
  "name": "crewcam-platform",
  "version": "1.0.0",
  "description": "Multi-tenant AI photobooth platform — create and deploy photobooths for many events from a single deployment.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "migrate": "node server/db/migrate.js",
    "seed": "node server/db/seed.js",
    "migrate:seed": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  }
}
